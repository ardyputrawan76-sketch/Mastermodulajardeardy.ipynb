            const s3 = parseInt(document.getElementById('score3').value) || 0;
            const finalGrade = ((s1 + s2 + s3) / 12) * 100;
            
            document.getElementById('liveGradeResult').innerText = finalGrade.toFixed(2) + " / 100";
            const statusEl = document.getElementById('liveGradeStatus');
            if (finalGrade >= 75) {
                statusEl.innerText = "MEMENUHI KKTP (>= 75)";
                statusEl.className = "bg-emerald-500/20 text-emerald-400 px-2.5 py-1 rounded text-[10px] font-bold border border-emerald-500/30";
