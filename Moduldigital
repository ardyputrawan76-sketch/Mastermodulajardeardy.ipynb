        // Call Custom API Wrapper with Exponential Backoff
        async function fetchGeminiApi(prompt, systemInstruction = "", retries = 5, delay = 1000) {
            const customKey = document.getElementById('customApiKey').value;
            const apiKey = customKey || ""; 
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;

            const payload = {
                contents: [{ parts: [{ text: prompt }] }]
            };
            if (systemInstruction) {
                payload.systemInstruction = { parts: [{ text: systemInstruction }] };
            }

            for (let i = 0; i < retries; i++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    if (response.ok) {
                        const data = await response.json();
                        return data.candidates?.[0]?.content?.parts?.[0]?.text || "";
                    }
                } catch (error) {
                    // Fail silently, retry
                }
                await new Promise(resolve => setTimeout(resolve, delay));
                delay *= 2; 
            }
            throw new Error("Gagal terhubung dengan server AI. Mohon periksa koneksi internet Anda.");
        }

